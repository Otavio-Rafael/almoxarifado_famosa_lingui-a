@using X.PagedList
@using X.PagedList.Mvc.Core
@model X.PagedList.IPagedList<Almoxarifado.Models.Classificacao>

@{
    ViewData["Title"] = "Classificações";
}

<h1>Classificações de Produtos</h1>

<p>
    <a asp-action="Create" class="btn btn-primary">Cadastrar Nova Classificação</a>
</p>

<table class="table table-hover">
    <thead>
        <tr>
            <th>@Html.DisplayNameFor(model => model.FirstOrDefault().Classifi)</th>
            <th>@Html.DisplayNameFor(model => model.FirstOrDefault().Descricacao)</th>
            <th></th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>@Html.DisplayFor(modelItem => item.Classifi)</td>
                <td>@Html.DisplayFor(modelItem => item.Descricacao)</td>
                <td>
                    <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-outline-warning">Editar</a>
                    <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-outline-info">Detalhes</a>
                  
                </td>
            </tr>
        }
    </tbody>
</table>

<div class="d-flex justify-content-between align-items-center mt-3">
    <small class="text-muted">
        Página @Model.PageNumber de @Model.PageCount — @Model.TotalItemCount classificação(ões) no total
    </small>
    @Html.PagedListPager(Model, pagina => Url.Action("Index", new { pagina }),
        new PagedListRenderOptions
        {
            LiElementClasses = new[] { "page-item" },
            PageClasses = new[] { "page-link" },
            UlElementClasses = new[] { "pagination" }
        })
</div>