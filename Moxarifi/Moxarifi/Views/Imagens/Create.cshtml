@model Moxarifi.Models.Imagem

@{
    ViewData["Title"] = "Cadastrar Imagem";
}

<div class="d-flex align-items-center mb-4">
    <h1 class="me-3">Cadastrar Imagem</h1>
    <a asp-action="Index" class="btn btn-outline-secondary btn-sm">← Voltar</a>
</div>

<div class="card" style="max-width: 600px;">
    <div class="card-header">
        <h5 class="mb-0">Nova Imagem</h5>
    </div>
    <div class="card-body">

        @if (ViewBag.Erro != null)
        {
            <div class="alert alert-danger">
                <i class="bi bi-exclamation-triangle"></i> @ViewBag.Erro
            </div>
        }

        <form asp-action="Create" enctype="multipart/form-data">
            <div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>

            <div class="mb-3">
                <label asp-for="ProdutoRefId" class="form-label fw-semibold"></label>
                <select asp-for="ProdutoRefId" class="form-select"
                        asp-items="ViewBag.ProdutoRefId">
                    <option value="">-- Selecione um produto --</option>
                </select>
            </div>

            <div class="mb-3">
                <label asp-for="Arquivo" class="form-label fw-semibold">Arquivos de Imagem</label>
                <input asp-for="Arquivo" class="form-control" type="file" multiple accept=".png,.jpg,.jpeg,.pdf" />
                <div class="form-text">Formatos aceitos: PNG, JPG, JPEG, PDF. Tamanho máximo: 10MB por arquivo.</div>
                <span asp-validation-for="Arquivo" class="text-danger"></span>
            </div>

            <!-- Preview das imagens antes de enviar -->
            <div id="preview" class="d-flex flex-wrap gap-2 mb-3"></div>

            <div class="d-flex gap-2">
                <input type="submit" value="Salvar" class="btn btn-primary" />
                <a asp-action="Index" class="btn btn-outline-secondary">Cancelar</a>
            </div>
        </form>

    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
    <script>
        // Preview das imagens selecionadas
        document.querySelector('input[type=file]').addEventListener('change', function () {
            const preview = document.getElementById('preview');
            preview.innerHTML = '';
            Array.from(this.files).forEach(file => {
                if (file.type.startsWith('image/')) {
                    const reader = new FileReader();
                    reader.onload = e => {
                        const img = document.createElement('img');
                        img.src = e.target.result;
                        img.style = 'width:100px;height:100px;object-fit:cover;border-radius:8px;border:1px solid #444;';
                        preview.appendChild(img);
                    };
                    reader.readAsDataURL(file);
                }
            });
        });
    </script>
}