@model Almoxarifado.Models.Produto

@{
    ViewData["Title"] = "Novo Produto";
}

<div class="d-flex align-items-center mb-4">
    <h1 class="me-3">Novo Produto</h1>
    <a asp-action="Index" class="btn btn-outline-secondary btn-sm">← Voltar</a>
</div>

<div class="card" style="max-width: 600px;">
    <div class="card-header">
        <h5 class="mb-0">Cadastrar Produto</h5>
    </div>
    <div class="card-body">
        <form asp-action="Create">
            <div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>

            <div class="mb-3">
                <label asp-for="Nome" class="form-label fw-semibold"></label>
                <input asp-for="Nome" class="form-control" placeholder="Nome do produto" />
                <span asp-validation-for="Nome" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="Descricao" class="form-label fw-semibold"></label>
                <textarea asp-for="Descricao" class="form-control" rows="3"
                          placeholder="Descreva o produto..."></textarea>
                <span asp-validation-for="Descricao" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="Quantidade" class="form-label fw-semibold"></label>
                <input asp-for="Quantidade" class="form-control" min="0" />
                <span asp-validation-for="Quantidade" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="ClassificacaoID" class="form-label fw-semibold"></label>
                <select asp-for="ClassificacaoID" class="form-select" asp-items="ViewBag.ClassificacaoID">
                    <option value="">-- Selecione uma classificação --</option>
                </select>
            </div>

            <div class="mb-3">
                <label asp-for="EstoqueID" class="form-label fw-semibold"></label>
                <select asp-for="EstoqueID" class="form-select" asp-items="ViewBag.EstoqueID">
                    <option value="">-- Selecione um setor --</option>
                </select>
            </div>

            <div class="d-flex gap-2 mt-4">
                <input type="submit" value="Salvar" class="btn btn-primary" />
                <a asp-action="Index" class="btn btn-outline-secondary">Cancelar</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}