@{
    ViewData["Title"] = "Início";
}

<div class="row g-4">

    <!-- Boas vindas -->
    <div class="col-12">
        <div class="card" style="background: linear-gradient(135deg, #1a1a2e, #2d1a0e); border: 1px solid #8B0000;">
            <div class="card-body d-flex align-items-center gap-4 p-4">
                <img src="~/Imagens/Logo.png" alt="Famosa Linguiça" style="height: 80px; object-fit: contain;" />
                <div>
                    <h2 class="mb-1" style="color: #fff;">Sistema de Almoxarifado</h2>
                    <p class="mb-0 text-muted">Gerencie o estoque da Famosa Linguiça Artesanal de Bragança Paulista</p>
                </div>
            </div>
        </div>
    </div>

    <!-- Cards de acesso rápido -->
    <div class="col-md-4">
        <a asp-controller="Produtos" asp-action="Index" class="text-decoration-none">
            <div class="card h-100 text-center p-3" style="border: 1px solid #375a7f; transition: all 0.2s;">
                <div class="card-body">
                    <i class="bi bi-box-seam" style="font-size: 2.5rem; color: #375a7f;"></i>
                    <h5 class="mt-3">Produtos</h5>
                    <p class="text-muted small">Cadastre e gerencie os produtos do estoque</p>
                </div>
            </div>
        </a>
    </div>

    <div class="col-md-4">
        <a asp-controller="MovimentacaoEstoques" asp-action="Index" class="text-decoration-none">
            <div class="card h-100 text-center p-3" style="border: 1px solid #00bc8c; transition: all 0.2s;">
                <div class="card-body">
                    <i class="bi bi-arrow-left-right" style="font-size: 2.5rem; color: #00bc8c;"></i>
                    <h5 class="mt-3">Movimentações</h5>
                    <p class="text-muted small">Registre entradas e saídas do estoque</p>
                </div>
            </div>
        </a>
    </div>

    <div class="col-md-4">
        <a asp-controller="Estoques" asp-action="Index" class="text-decoration-none">
            <div class="card h-100 text-center p-3" style="border: 1px solid #f39c12; transition: all 0.2s;">
                <div class="card-body">
                    <i class="bi bi-building" style="font-size: 2.5rem; color: #f39c12;"></i>
                    <h5 class="mt-3">Setores</h5>
                    <p class="text-muted small">Gerencie os locais de armazenamento</p>
                </div>
            </div>
        </a>
    </div>

    <!-- Sobre a empresa -->
    <div class="col-md-6">
        <div class="card h-100">
            <div class="card-header">
                <h5 class="mb-0"><i class="bi bi-info-circle me-2"></i>Sobre a Famosa</h5>
            </div>
            <div class="card-body">
                <p>A Famosa nasceu da inquietação de Luiz Américo, que transformou a tradição familiar em um negócio de sucesso. Hoje é referência em linguiça artesanal em Bragança Paulista.</p>
                <ul class="list-unstyled">
                    <li><i class="bi bi-check-circle text-success me-2"></i>Mais de 35 sabores artesanais</li>
                    <li><i class="bi bi-check-circle text-success me-2"></i>Linha Famosíssima e Linha Tradicional</li>
                    <li><i class="bi bi-check-circle text-success me-2"></i>Produção semanal fresca</li>
                    <li><i class="bi bi-check-circle text-success me-2"></i>Venda no atacado disponível</li>
                </ul>
            </div>
        </div>
    </div>

    <!-- Localização -->
    <div class="col-md-6">
        <div class="card h-100">
            <div class="card-header">
                <h5 class="mb-0"><i class="bi bi-geo-alt me-2"></i>Localização</h5>
            </div>
            <div class="card-body">
                <p>
                    <i class="bi bi-pin-map text-danger me-2"></i>Rod. Cap. Bardoino, S/N – km 99,5<br>
                    Curitibanos, Bragança Paulista – SP
                </p>
                <p>
                    <i class="bi bi-clock me-2 text-warning"></i>
                    Segunda a Sexta: 09:30 – 18:00<br>
                    <span style="margin-left: 1.5rem;">Fins de semana e feriados: 09:30 – 19:00</span>
                </p>
                <a href="https://maps.app.goo.gl/mdHDTYMAvPLPyfWdA" target="_blank" class="btn btn-outline-success btn-sm">
                    <i class="bi bi-map me-1"></i> Ver no Maps
                </a>
            </div>
        </div>
    </div>

</div>